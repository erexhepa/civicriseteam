# Anthropic configuration
# IMPORTANT: Use ANTHROPIC_API_KEY (without VITE_ prefix) to keep it server-side only
# This prevents the API key from being exposed in the client-side bundle
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Convex configuration
VITE_CONVEX_URL=your-convex-deployment-url-here

# Sentry configuration
VITE_SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# Netlify-native RAG configuration
# Comma-separated official source URLs to crawl on scheduled indexing.
NETLIFY_RAG_SOURCE_URLS=https://www.montgomeryal.gov/,https://www.montgomeryal.gov/services

# Optional Blob store name for the RAG index.
NETLIFY_RAG_STORE=civic-rag

# Retrieval tuning.
NETLIFY_RAG_TOP_K=5

# Standard chunking parameters for raw text indexing.
NETLIFY_RAG_CHUNK_SIZE=1000
NETLIFY_RAG_CHUNK_OVERLAP=200

# Safety caps to avoid serverless timeouts/internal errors.
NETLIFY_RAG_MAX_SOURCES_PER_RUN=10
NETLIFY_RAG_MAX_CHUNKS_PER_SOURCE=500
NETLIFY_RAG_FETCH_TIMEOUT_MS=15000

#Important! Never commit your `.env` file to version control as it contains sensitive information.